# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_SECRET=your_random_webhook_secret_here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/telegram_analytics

# JWT Auth
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Admin credentials (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# App
APP_HOST=0.0.0.0
APP_PORT=8000
